# ─── MongoDB ─────────────────────────────────────────────
# Required for workflow persistence (sessions, tasks, code files).
# Without this, all state is lost on server restart / page reload.
# Local:   mongodb://localhost:27017/ai-team
# Atlas:   mongodb+srv://<user>:<pass>@cluster.mongodb.net/ai-team
MONGODB_URI=mongodb://localhost:27017/ai-team

# ─── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=sk-


# ─── OAuth App Credentials (for runtime integrations) ────
GITHUB_CLIENT_ID=Ov23liK2QdtrWkdRcEI7
GITHUB_CLIENT_SECRET=58399a55d737519c6fcbfb1ebb2a7b9db84


# JIRA
JIRA_CLIENT_ID=LHO
JIRA_CLIENT_SECRET=ATO

# Base URL for OAuth callbacks
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Fashion Stylist (scraper) ────────────────────────────
# On Vercel, Zara/Bershka/Massimo Dutti often return 403 (they block datacenter IPs).
# Set SCRAPPER_API_KEY (ScraperAPI) to route requests through their proxy.
# Leave empty for local dev (usually works from a residential IP).
SCRAPPER_API_KEY=

# ─── Vercel ──────────────────────────────────────────────
# Token from https://vercel.com/account/tokens
VERCEL_TOKEN=...
# Project ID visible in Vercel project settings
FULL_AI_VERCEL_PROJECT_ID=prj_...
# Optional — leave blank for personal account
VERCEL_TEAM_ID=

MONGODB_URI=...
