# ─── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── GitHub ───────────────────────────────────────────────
# Personal access token with repo + issues scope
GITHUB_TOKEN=ghp_...
# Default owner/repo used when agents create issues
GITHUB_OWNER=vahagnvardanyan1
GITHUB_REPO=example-openclaw

# ─── Jira ─────────────────────────────────────────────────
# Base URL of your Jira Cloud instance (no trailing slash)
JIRA_BASE_URL=https://your-domain.atlassian.net
# Email of the Jira account that owns the API token
JIRA_EMAIL=you@example.com
# API token generated at https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=ATATT3x...
# Project key where tickets are created
JIRA_PROJECT_KEY=PROJ

# ─── Vercel ──────────────────────────────────────────────
# Token from https://vercel.com/account/tokens
VERCEL_TOKEN=...
# Project ID visible in Vercel project settings
VERCEL_PROJECT_ID=105f9280
