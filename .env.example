# ─── MongoDB ─────────────────────────────────────────────
# Required for workflow persistence (sessions, tasks, code files).
# Without this, all state is lost on server restart / page reload.
# Local:   mongodb://localhost:27017/ai-team
# Atlas:   mongodb+srv://<user>:<pass>@cluster.mongodb.net/ai-team
MONGODB_URI=mongodb

# ─── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── GitHub ───────────────────────────────────────────────
# Personal access token with repo + issues scope
GITHUB_TOKEN=ghp_...
# Default owner/repo used when agents create issues
GITHUB_OWNER=your-org
GITHUB_REPO=your-repo


# ─── Vercel ──────────────────────────────────────────────
# Token from https://vercel.com/account/tokens
VERCEL_TOKEN=...
# Project ID visible in Vercel project settings
VERCEL_PROJECT_ID=prj_...
# Optional — leave blank for personal account
VERCEL_TEAM_ID=
